<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
  <fullName>SuggestedFare__c</fullName>
  <label>Suggested Fare</label>
  <type>Currency</type>
  <precision>10</precision>
  <scale>2</scale>
  <formula>ROUND((BaseFare__c + (DistanceKm__c * RatePerKm__c)) * SurgeMultiplier__c, 0)</formula>
  <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
</CustomField>

